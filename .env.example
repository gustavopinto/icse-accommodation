# Copie para .env e preencha com seus valores. Nunca commite o .env.
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=sua-chave-secreta

# PostgreSQL (ex.: Neon, Supabase, local). Nunca commitar a URL com credenciais.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Login do painel admin (/admin/login) é validado pela tabela `admins`.
# Para criar o primeiro administrador: python scripts/seed.py
