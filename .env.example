# Copie para .env e preencha com seus valores. Nunca commite o .env.
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=sua-chave-secreta

# PostgreSQL. Nunca commitar a URL com credenciais.
# Local (sem SSL): postgresql://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO
# Ex.: postgresql://postgres:postgres@localhost:5432/icse_accommodation
# Neon/Supabase (com SSL): postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Login do painel admin (/admin/login) — tabela `admins`. Criar com: python scripts/seed.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD=senha-segura
